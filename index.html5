<h2>Jeux disponibles sur mobile</h2>




<div class="row" id="gamesRow">








    <!-- TU AJOUTES TES JEUX ICI -->
    <!-- FORMAT : data-title doit contenir le nom du jeu -->
<a href="jeux2.html" class="card" data-title="exive"  data-duration="10"   data-tags="arcade,reflexes,mobile">
        <img src="Capture d’écran 2026-02-16 105203.png">
        <div class="card-title">exive</div>












    </a>















<script>
    // RECHERCHE DYNAMIQUE
    const search = document.getElementById("search");
    const cards = document.querySelectorAll(".card");




    search.addEventListener("input", () => {
        const q = search.value.toLowerCase();




        cards.forEach(card => {
            const title = card.dataset.title.toLowerCase();
            card.style.display = title.includes(q) ? "block" : "none";
        });
    });


// DÉFILEMENT AVEC FLÈCHES
    function scrollRow(direction) {
        const row = document.getElementById("gamesRow");
        const scrollAmount = 350; // Distance de défilement
        row.scrollBy({
            left: direction * scrollAmount,
            behavior: 'smooth'
        });
    }








</script>












<script>
    const durationFilter = document.getElementById("durationFilter");




    durationFilter.addEventListener("change", () => {
        const selected = durationFilter.value;




        cards.forEach(card => {
            const duration = card.dataset.duration;




            // Si aucune durée sélectionnée → tout afficher
            if (selected === "") {
                card.style.display = "block";
                return;
            }




            // Sinon afficher seulement les jeux qui matchent
            card.style.display = (duration === selected) ? "block" : "none";
        });
    });
</script>




<script>
    const search = document.getElementById("search");
    const durationFilter = document.getElementById("durationFilter");
    const cards = document.querySelectorAll(".card");




    function applyFilters() {
        const q = search.value.toLowerCase();
        const selectedDuration = durationFilter ? durationFilter.value : "";




        cards.forEach(card => {
            const title = card.dataset.title.toLowerCase();
            const duration = card.dataset.duration;




            const matchTitle = title.includes(q);
            const matchDuration = selectedDuration === "" || duration === selectedDuration;




            if (matchTitle && matchDuration) {
                card.classList.remove("hide");
            } else {
                card.classList.add("hide");
            }
        });
    }




    search.addEventListener("input", applyFilters);
    if (durationFilter) durationFilter.addEventListener("change", applyFilters);








</script>




<script>
    (function() {
        const user   = localStorage.getItem('reevox_user');
        const expiry = localStorage.getItem('reevox_subscription_expiry');
        if (!user || !expiry || parseInt(expiry) < Date.now()) {
            window.location.href = 'paiement.html';
        }
    })();
</script>





<script src="reevox-mini-player.js"></script>





