<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Reevox - Jeux</title>




<!-- Favicon -->
<link rel="icon" type="image/x-icon" href="IMG_8395.png">




<style>
    body {
        margin: 0;
        background: #000814;
        font-family: Arial, sans-serif;
        color: white;
    }




    /* HEADER */
    header {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 15px 40px;
        background: rgba(0,0,0,0.7);
        backdrop-filter: blur(10px);
        position: sticky;
        top: 0;
        z-index: 100;
    }




    .logo {
    height: 110px;
    object-fit: contain;
}




    .search-box {
        margin-left: auto;
        position: relative;
    }




    .search-box input {
        padding: 8px 15px;
        border-radius: 20px;
        border: none;
        outline: none;
        background: rgba(255,255,255,0.1);
        color: white;
        width: 220px;
        transition: 0.3s;
    }




    .search-box input:focus {
        background: rgba(4, 83, 105, 0.2);
        box-shadow: 0 0 10px #00eaff;
    }




    /* TITRE */
    h2 {
        margin: 25px 40px 10px;
        font-size: 24px;
        font-weight: bold;
    }




    /* LIGNE NETFLIX */
    .row {
        display: flex;
        overflow-x: auto;
        gap: 20px;
        padding: 10px 40px 40px;
        scroll-behavior: smooth;
    }




    .row::-webkit-scrollbar {
        height: 8px;
    }




    .row::-webkit-scrollbar-thumb {
        background: rgba(255,255,255,0.25);
        border-radius: 10px;
    }




    /* CARTE JEU */
    .card {
        flex: 0 0 auto;
        width: 330px;
        text-decoration: none;
        color: white;
        transition: 0.3s;
        position: relative;
    }




    .card img {
        width: 100%;
        height: 180px;
        object-fit: cover;
        border-radius: 12px;
        transition: 0.3s;
        box-shadow: 0 10px 25px rgba(0,0,0,0.7);
    }




    .card:hover {
        transform: scale(1.08);
    }




    .card:hover img {
        filter: brightness(1.15);
    }




    .card-title {
        margin-top: 8px;
        font-size: 17px;
        font-weight: bold;
        text-shadow: 0 0 8px black;
    }




    /* ANIMATION */
    .row {
        opacity: 0;
        transform: translateY(20px);
        animation: fadeIn 0.7s forwards;
    }




    @keyframes fadeIn {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }








/* STYLE DU FILTRE DE DURÉE */
#durationFilter {
    padding: 8px 15px;
    border-radius: 20px;
    border: none;
    outline: none;
    background: rgba(255,255,255,0.1);
    color: white;
    font-size: 15px;
    cursor: pointer;
    transition: 0.3s;
    backdrop-filter: blur(6px);
    box-shadow: 0 0 10px rgba(0,229,255,0.15);
}




/* Effet au survol */
#durationFilter:hover {
    background: rgba(0,229,255,0.2);
    box-shadow: 0 0 15px rgba(0,229,255,0.4);
}




/* Effet au clic */
#durationFilter:focus {
    background: rgba(0,229,255,0.25);
    box-shadow: 0 0 20px rgba(0,229,255,0.6);
}




/* Style des options */
#durationFilter option {
    background: #001220;
    color: white;
    border: none;
}




/* Animation d’apparition fluide */
.card {
    opacity: 1;
    transform: scale(1) translateY(0);
    transition: opacity 0.35s ease, transform 0.35s ease;
}




/* Quand un jeu est masqué */
.card.hide {
    opacity: 0;
    transform: scale(0.85) translateY(10px);
    pointer-events: none;
}
















.meme-button img {
    width: 125px; /* taille parfaite comme tu voulais */
    border-radius: 12px;
    border: 3px solid white; /* contour blanc visible */
    cursor: pointer;
    transition: 0.3s;
    box-shadow: 0 8px 20px rgba(255,255,255,0.2); /* léger halo blanc */
}




.meme-button img:hover {
    transform: scale(1.08);
    filter: brightness(1.15);
    box-shadow: 0 0 20px rgba(255,255,255,0.6); /* effet glow au survol */
}






/* FLÈCHES */
    .scroll-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(0, 0, 0, 0.7);
        backdrop-filter: blur(10px);
        border: 2px solid rgba(0, 234, 255, 0.3);
        color: #00eaff;
        width: 50px;
        height: 50px;
        border-radius: 50%;
        cursor: pointer;
        z-index: 10;
        transition: 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        font-weight: bold;
        opacity: 0.7;
    }


    .scroll-btn:hover {
        opacity: 1;
        background: rgba(0, 234, 255, 0.2);
        box-shadow: 0 0 20px rgba(0, 234, 255, 0.5);
        transform: translateY(-50%) scale(1.1);
    }


    .scroll-btn-left {
        left: 10px;
    }


    .scroll-btn-right {
        right: 10px;
    }






    /* ═══════════════════════════════════════════════════ */
/* COLLE CE CSS DANS TON <style> EXISTANT             */
/* Fonctionne uniquement sur téléphone (max 768px)    */
/* ═══════════════════════════════════════════════════ */

@media (max-width: 768px) {

    /* ── HEADER ── */
    header {
        padding: 10px 16px;
        gap: 8px;
        flex-wrap: wrap;
        justify-content: space-between;
    }

    .logo {
        height: 55px;
    }

    /* Cacher le filtre durée sur mobile (trop petit) */
    #durationFilter {
        display: none;
    }

    /* Barre de recherche prend toute la largeur */
    .search-box {
        margin-left: 0;
        width: 100%;
        order: 10; /* passe en bas du header */
    }

    .search-box input {
        width: 100%;
        box-sizing: border-box;
        padding: 10px 18px;
        font-size: 15px;
    }

    /* Boutons meme plus petits */
    .meme-button img {
        width: 44px;
        height: 44px;
        object-fit: cover;
        border-radius: 10px;
        border-width: 2px;
    }

    /* ── TITRES ── */
    h2 {
        margin: 20px 16px 8px;
        font-size: 18px;
    }

    /* ── LIGNES DE JEUX ── */
    .row {
        padding: 8px 16px 24px;
        gap: 14px;
        /* Snap scroll pour mobile */
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
    }

    /* ── CARTES ── */
    .card {
        width: 200px;
        scroll-snap-align: start;
    }

    .card img {
        height: 120px;
        border-radius: 10px;
    }

    .card-title {
        font-size: 14px;
        margin-top: 6px;
    }

    /* ── FLÈCHES (cachées sur mobile, on swipe) ── */
    .scroll-btn {
        display: none;
    }

    /* ── BOUTON MOOD ── */
    #moodBar {
        margin: 10px 16px !important;
        gap: 8px !important;
    }

    .mood-btn {
        padding: 8px 14px;
        font-size: 12px;
    }

    /* Bouton "Comment tu te sens" */
    header + div {
        margin: 14px 16px 0 !important;
    }

    /* ── SECTION SUGGÉRÉS ── */
    #suggestedSection h2 {
        margin: 20px 16px 8px !important;
        font-size: 18px !important;
    }

    #suggestedRow {
        padding: 8px 16px 24px !important;
        gap: 14px !important;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
    }

    .sug-card {
        width: 180px !important;
        scroll-snap-align: start;
    }

    .sug-card img {
        height: 110px !important;
    }

    .sug-card-title {
        font-size: 13px !important;
    }

    .sug-reason {
        font-size: 10px !important;
    }
}



   












</style>
</head>




<body>




